{
  "name": "hms-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "npm run test:unit && npm run test:auth && npm run test:advanced",
    "test:unit": "mocha tests/task-model.test.js tests/task-routes.test.js --exit",
    "test:auth": "mocha tests/task-auth.test.js --exit --timeout 60000",
    "test:advanced": "mocha tests/task-advanced.test.js --exit --timeout 60000",
    "test:all": "npm run test:unit && npm run test:auth && npm run test:advanced",
    "test:watch": "mocha tests/task-model.test.js --watch --exit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.11.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.3.1",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "mocha": "^11.7.6",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
